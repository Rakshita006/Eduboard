# Database
MONGODB_URI=your_mongodb_uri_here

# Auth
JWT_SECRET=your_jwt_secret_here
PORT=5000

# Nodemailer (Gmail App Password)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_smtp_password_here

# Admin
ADMIN_EMAIL=admin_email_here

# Frontend URL
CLIENT_URL=http://localhost:5173

# Resend Email Service
RESEND_API_KEY=re_your_resend_api_key_here

# Email Provider Toggle (set to "true" to use Gmail, "false" to use Resend)
USE_GMAIL=true

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Environment
NODE_ENV=development

# Rate Limiting (Optional - in milliseconds) # ← NEW
AUTH_LIMIT_WINDOW_MS=900000 # ← NEW
AUTH_LIMIT_MAX=10 # ← NEW
OTP_LIMIT_WINDOW_MS=600000 # ← NEW
OTP_LIMIT_MAX=5 # ← NEW
GLOBAL_AUTH_LIMIT_WINDOW_MS=900000 # ← NEW
GLOBAL_AUTH_LIMIT_MAX=100 # ← NEW

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id_here